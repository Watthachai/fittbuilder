# Google AI Studio API key — https://aistudio.google.com/apikey
# (GOOGLE_API_KEY is also accepted)
GEMINI_API_KEY=

# Optional: override the Gemini model used for generation.
# Default: gemini-2.5-flash (fast). Use gemini-2.5-pro for higher quality.
GEMINI_MODEL=gemini-2.5-flash

# Supabase (cloud auth + storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — used for admin writes to skill templates (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=
# DMAIL transactional email (team invites)
DMAIL_API_KEY=
# Admins who can author skill templates — comma-separated; each entry is a full
# email or a "@domain" suffix. e.g. @digitalvalue.co.th,wattchaichai@gmail.com
ADMIN_EMAILS=

# Optional: distributed rate limiting via Upstash Redis. Set BOTH to switch the
# API rate limiter from per-instance in-memory to a shared store (needed when
# deploying across multiple serverless instances). Leave blank for local/single
# instance — the in-memory fallback is used automatically.
# Create a free DB at https://console.upstash.com → REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
